# ============================================================
# GC ImageAI Backend — Environment Variables
# Copy this file to .env and fill in all values before running.
# NEVER commit .env to version control.
# ============================================================

# ---- Server ------------------------------------------------
NODE_ENV=development
PORT=3000

# CORS origin for the API (use * in dev, restrict in prod)
CORS_ORIGIN=*

# ---- Database (Supabase / PostgreSQL) ----------------------
# Find in: Supabase Dashboard → Project Settings → Database → Connection string
# Use the "Transaction" pooler URL for Railway deploys (port 6543)
DATABASE_URL=postgresql://postgres:<password>@<host>:5432/<database>

# ---- JWT ---------------------------------------------------
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_byte_hex_secret
JWT_EXPIRES_IN=30d

# ---- Apple Sign-In -----------------------------------------
# Your iOS app bundle ID (e.g. com.yourcompany.gcimageai)
APPLE_APP_BUNDLE_ID=com.yourcompany.gcimageai

# ---- Cloudflare R2 -----------------------------------------
# Account ID: Cloudflare Dashboard → R2 → Account ID (top right)
# Endpoint format: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com

# R2 bucket name (create in Cloudflare R2 dashboard)
R2_BUCKET_NAME=gc-imageai-images

# R2 API token credentials (Cloudflare Dashboard → R2 → Manage API Tokens)
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key

# Optional: public CDN URL for the bucket (if you've enabled public access).
# If set, generated image URLs will use this domain instead of presigned URLs.
# Example: https://images.yourdomain.com
R2_PUBLIC_URL=

# ---- SiliconFlow (AI Image Generation) ---------------------
# API key from: https://cloud.siliconflow.cn → API Keys
SILICONFLOW_API_KEY=sk-your_siliconflow_api_key

# ---- RevenueCat (Subscription & IAP Management) ------------
# All subscription and in-app purchase logic is handled by RevenueCat.
# Stripe and raw StoreKit code have been removed.
#
# Dashboard: https://app.revenuecat.com
#
# Public API key — used in the iOS SDK (Purchases.configure(withAPIKey:))
# Safe to include in the app bundle; does NOT go here (goes in Xcode).
# Listed here for reference only:
# REVENUECAT_PUBLIC_API_KEY=test_DSVjgvqfgizAaTiaIsfcgzqzcua
#
# Secret key — used for server-side REST API calls. KEEP THIS PRIVATE.
# RevenueCat Dashboard → Project Settings → API Keys → Secret keys
REVENUECAT_SECRET_KEY=your_revenuecat_secret_key

# Webhook auth secret — set this in RevenueCat Dashboard → Project Settings → Webhooks
# Use any strong random string; add the same value in RevenueCat's webhook config.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
REVENUECAT_WEBHOOK_SECRET=your_revenuecat_webhook_secret

# RevenueCat entitlement identifiers — must match what's set up in RC dashboard
# RevenueCat Dashboard → Project → Entitlements
REVENUECAT_ENTITLEMENT_PRO=pro
REVENUECAT_ENTITLEMENT_ULTRA=ultra

# ---- Admin Dashboard ---------------------------------------
# A strong random secret to protect the admin dashboard.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Access dashboard at: http://localhost:3000/admin?key=<this_value>
ADMIN_SECRET_KEY=replace_with_strong_random_secret
